#!/bin/bash
# Pre-commit hook: lockfile sync + typecheck + secrets

echo "🔍 Running pre-commit checks..."

GIT_COMMON=$(git rev-parse --git-common-dir)
MAIN_ROOT=$(dirname "$GIT_COMMON")

# Check every bun.lock is in sync (BLOCKING).
#
# This checks ALL lockfiles, not just the root one. web/bun.lock drifted once and
# went unnoticed for months because only the root was checked: a plain local
# `bun install` happily updates the lockfile in memory, but Railway sets CI=true,
# which makes bun default to --frozen-lockfile — so the drift only ever surfaced
# as a failed deploy, never locally.
echo "  📦 Checking bun.lock files are up to date..."
LOCK_FAIL=0
while IFS= read -r lock; do
  dir=$(dirname "$lock")
  rel=${dir#"$MAIN_ROOT"/}
  [ "$dir" = "$MAIN_ROOT" ] && rel="."
  if ! out=$(bun install --frozen-lockfile --dry-run --cwd "$dir" 2>&1); then
    echo ""
    echo "❌ $rel/bun.lock is out of sync with $rel/package.json."
    echo "   $(echo "$out" | grep -i 'error' | head -1)"
    echo "   Run 'bun install' in $rel/, then re-stage $rel/bun.lock."
    LOCK_FAIL=1
  fi
done < <(find "$MAIN_ROOT" -name bun.lock -not -path '*/node_modules/*' -not -path '*/.next/*')
[ "$LOCK_FAIL" -ne 0 ] && exit 1

# TypeScript check (BLOCKING) — tsconfig lives in web/
echo "  📝 TypeScript type check..."
if [ -f "$MAIN_ROOT/web/tsconfig.json" ]; then
  # Clear stale .next cache to avoid missing-generated-types errors
  rm -rf "$MAIN_ROOT/web/.next"
  cd "$MAIN_ROOT/web" && bunx tsc --noEmit
  if [ $? -ne 0 ]; then
    echo ""
    echo "❌ TypeScript errors found. Commit blocked."
    exit 1
  fi
else
  echo "  ⚠️  No web/tsconfig.json found, skipping TS check"
fi

# Check for secrets (BLOCKING)
echo "  🔒 Checking for secrets..."
if git diff --cached | grep -iE '(api[_-]?key|secret|password|token|private[_-]?key).*=.*["'"'"'][a-zA-Z0-9_-]{20,}'; then
  echo ""
  echo "❌ Potential secret detected. Commit blocked."
  exit 1
fi

echo "✅ All pre-commit checks passed"
exit 0
